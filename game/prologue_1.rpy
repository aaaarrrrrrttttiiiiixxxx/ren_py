# Пролог 1: Кабинет Школьного совета
# Основан на файле "Диалоги/Пролог 1 Кабинет Школьного совета.md"

define s = Character('Шинна Кудо', color="#ff6b9d")
define a = Character('Алиса Тогаши', color="#6bc5ff")
define m = Character('Мари Аясэ', color="#ffb86b")
define l = Character('Леон Грей', color="#b8b8ff")
define n = Character(None, color="#ffffff")
define seller = Character('Продавец', color="#aaaaaa")

default leon_strength = 0
default leon_intellect = 0
default leon_mystic = 0
default leon_organization = 0
default leon_empathy = 0



label prologue_1_scene_1:
    scene black
    with dissolve

    "Локация: Кабинет Школьного совета"

    show shinna_smile_blush
    s "Всех, приветствую на собрании школьного совета"
    show alice_smile
    a "Привет"
    show mari_smile
    m "Приветики"
    l "*Хррр*..."
    show shinna_closed_frown
    s "(сердито) Леон?"
    s "Мы начинаем!"
    
    l "совсем нет времени на сон..."
    l "Добрый вечер)"
    show shinna_closed_frown
    s "(сердито) Хмм..."
    show shinna_smile
    s "Начнем с хороших новостей!"
    s "Мы хорошо постарались над проведением церемонии награждения участников олимпиады по математике"
    s "Также директор высказал благодарность за организацию спортивных соревнований, которые прошли на прошлой неделе"
    show mari_smile
    m "Оу, замечательно"
    s "Директор увеличил финансирование нашего совета,"
    show alice_smile
    a "(радостно) А вот это действительно хорошие новости!"
    s "Так что теперь мы сможем помочь еще большему числу учащихся!"
    show alice_frown
    a "(растроенно) ..."
    s "И теперь директор просит помочь в проведении бала маскарада в стенах нашей школы..."
    l "Хорошо, справимся"
    l "Какой срок?"
    s "Один вечер"
    s "Завтра"
    s "Бал состоится завтра"
    s "Сегодня завершилась генеральная репетиция театрального кружка в актовом зале."
    s "Нам нужно прибрать зал и подготовить его к завтрашнему дню."
    show mari_frown
    m "Ох, времени совсем мало..."
    show shinna_frown
    s "Да, я все понимаю"
    s "Мне очень жаль, что я так поздно сообщаю об этом"
    s "Я сама взялась за это, не спросив вашего мнения"
    s "Если вы откажетесь, я все пойму..."
    show mari_smile
    m "Шинна-тян, ты чего"
    m "Конечно мы останемся и поможем!"
    m "Так ведь ребята?"
    show alice_closed_frown
    a "(испуганно) (Конечно у меня нет никаких дел...)"
    a "(Но...)"
    a "(Оставаться в школе на ночь...)"
    a "(Темные страшные коридоры, пустые гнетущие кабинеты..)"
    a "(Так, Алиса, соберись. Помочь Шинне, это твой долг как члена школьного совета)"
    a "(К тому же на улице как-то рано темнеет)"
    a "(Идти домой в одиночку тоже не хочется...)"
    show alice_smile
    a "Да, кончено! Я с вами..."
    l "..."
    show shinna_frown
    s "Леон? У тебя какие-то дела?"
    l "Как я и сказал, скоро экзамены..."
    l "Но конечно я не оставлю вас без своей помощи!"
    n "Алиса вздохнула с облегчением..."
    show shinna_smile
    s "Спасибо, Леон"
    s "Ты очень..."
    s "Выручишь!"
    s "Если будут вопросы по учебе, обращайся ко мне или к девочкам"
    s "Я думаю они не откажут..."
    show mari_smile
    m "Да, Леон, что там у тебя?"
    m "Электродинамика?"
    m "Мы проходили ее в прошлом году..."
    m "Чем смогу помогу!"
    show alice_closed_smile
    a "Школьную программу электродинамики я освоила еще в 12 лет"
    a "Так что буду рада выступить твоим наставником!"
    l "Спасибо, девочки"
    l "Возможно моим бессонным ночам придет конец!"
    show shinna_smile
    s "Еще раз спасибо всем за помощь!"
    s "Вечер, вероятно, будет долгим, нужно запастись едой."
    l "Я был бы не прочь развеется"
    l "Могу сходить."
    show alice_smile
    a "Я с тобой!"
    a "Тебе же нужна помощь с электродинамикой?.."
    show shinna_smile
    s "Отлично!"
    s "Вы идите за едой, а мы с Мари закончим дела уч совета!"
    n "Леон и Алиса надевают верхнюю одежду и отправляются на улицу"

    jump prologue_1_scene_2

label prologue_1_scene_2:
    scene black
    with dissolve

    "Локация: Улица"

    n "Алиса и Леон отправляются по тротуару до ближайшего ларька с едой"

    show alice_smile
    a "Слушай, силу тока, можно посчитать как отношение напряжения к сопротивлению на резисторе"
    a "Но это верно только для участка цепи..."
    l "Прости, мне довольно тяжело воспринимать на слух..."
    a "Для полной цепи еще нужно учитывать сопротивление источника"
    a "Так тебе нужна помощь или нет?"
    l "Да, да, извини"
    l "Внимательно слушаю"
    show alice_closed_smile
    a "Хорошо, чтобы научиться решать задачи на схемы электрических цепей..."
    a "Нужно уметь разбивать цепь на составные части"
    a "Всего есть два базовых типа соединения цепей"
    a "Последовательное и Параллельное"
    a "Те формулы из учебника, которые ты не умеешь применять, они как раз служат для подсчета основных параметров"
    a "Сила тока, Напряжение и Сопротивление"
    a "Тебе нужно просто понять какой перед тобой тип соединения и применить правильную формулу!"
    n "Увлекшись рассказом, Алиса очень близко подходит к проезжей части"
    n "Проезжающая мимо машина, громко сигналит"
    show alice_closed_frown_blush
    a "(Испуганно) ..."
    n "Алиса крепко прижимается к Леону"
    n "И также резко отстраняется..."
    show alice_shout
    a "(возмущенно) Ну что ты встал на пути?"
    a "Мог бы и предупредить, что едет машина"
    l "Прости, ты так увлеченно рассказывала"
    l "А я увлеченно слушал"
    l "Впитывал информацию как губка"
    show alice_smile_blush
    a "(смущенно) ..."
    a "Ты не подумай, мы с тобой члены уч совета"
    a "И очень важно, чтобы мы все хорошо сдали экзамены"
    a "Поэтому я тебе и помогаю"
    n "Леон подходит к ларьку и заглядывает в окошко"

    seller "Добрый вечер, что будете заказывать?"
    l "Здравствуйте!"
    l "Будьте добры, 4 вока и 4 онигири с тунцом, пожалуйста"
    a "И 1 шоколадный батончик!"
    a "Пожалуйста"
    seller "5 минут и все будет готово!"
    seller "3 тысячи йен, пожалуйста"
    n "Продавец отдает блюда Леону"
    n "Герои возвращаются обратно в кабинет школьного совета"

    jump prologue_1_scene_3

label prologue_1_scene_3:
    scene black
    with dissolve

    "Локация: Кабинет Школьного совета"

    show shinna_smile
    show mari_smile
    s "О, вы как раз во время!"
    m "Да, мы почти закончили с бумажной волокитой!"
    s "Алиса, можешь пожалуйста, просмотреть бухгалтерские отчетности за прошлый месяц?"
    s "Нужен твой зоркий глаз и умение быстро считать"
    show alice_smile
    a "Да, кончено, плевое дело"
    s "Леон, а тебя я хочу попросить проверить одну из статей на наличие орфографических ошибок"
    s "Нам отправили несколько статей для публикации на новостном портале"
    s "Можешь выбрать любую."
    l "Конечно, нет проблем."

    n "Список статей для публикации."

    call prologue_1_article_choice

    show alice_smile
    a "Я закончила! С отчетностью все в порядке"
    show shinna_smile
    s "Отлично, я тоже"
    s "Леон?"
    l "Да-да."
    l "Проверил."
    l "Ошибок вроде нет."
    show mari_smile
    m "Отличненько..."
    m "Можем выдвигаться?"
    show shinna_smile
    s "Да, выходите, я закрою кабинет"
    n "Шинна гасит свет в аудитории"
    n "..."
    n "Дважды проворачивает ключ"

    jump prologue_2_scene_1

label prologue_1_article_choice:
    menu:
        "Выберите статью для проверки:"

        "«Спорт калечит — физкультура лечит» — важность безопасного спорта и анализ здоровья своего организма.":
            n "Все мы знаем парня, который после физры ходит как робот с разряженной батарейкой. На прошлой неделе Ито-кун решил эффектно финишировать в беге и приземлился на лоб — теперь у него шишка размером с мандарин. А Накамура-сан на растяжке зачем-то попыталась сесть на шпагат за секунду и две недели хромала. Незу-кун вообще так увлекся игрой в лапту, что влетел в стену и сломал руку."
            n "Мы опросили 50 учеников: 48 из них хотя бы раз получали лёгкую травму на уроке. Самое популярное — удар мячом в лицо и растяжение после рывка. Главные причины две: желание понтоваться и отсутствие нормальной разминки."
            n "Как понять, что организм говорит «стоп»? Если мир перед глазами плывёт, ты слышишь собственный хруст или колено сгибается не туда — остановись. Разминка — это не время поболтать, это подготовка организма к физическим нагрузкам."
            n "Занимайся в своём темпе. Лучше отжаться от стены и быть здоровым, чем отжаться 50 раз от пола и лежать пластом. Физкультура лечит, а вот спорт калечит тех, кто забыл, что тело — не игрушка."
            $ leon_strength += 1
            n "Сила Леона увеличена на 1"
            jump prologue_1_article_continue

        "«Дебют Гроба» — сильнейшее начало на шахматном турнире.":
            n "В минувшую пятницу в стенах нашей школы прошёл турнир по шахматам, который уже окрестили «битвой титанов и одного диванного стратега». Главная сенсация — победная стратегия ученика 2 класса старшей школы Танаки-куна, который на все партии заявлял один и тот же первый ход: g2-g4 (известный в узких кругах как «Дебют Гроба»). Все опытные шахматисты при виде такого хода сначала хватались за головы, а потом — за учебники шахматных дебютов, потому что это начало считается одним из худших. Но Танаки-кун невозмутимо отвечал: «Гроб — это не про меня, это про тех, кто не готов к моей тактике». И о чудо: двое соперников от неожиданности зевнули ладью, а третий так долго смеялся над ходом g2-g4, что просрочил время. В финале Танаки-кун несколько изменил тактику, совершив 8 ходов пешками подряд, соорудив целую плотину из пешек на 6 горизонтали. Кто бы мог подумать, но и эта стратегия принесла парню победу. Пусть организаторы и подозревают лёгкий сговор со стороны судьи (который, к слову, лучший друг Танаки), но факт остаётся фактом: «Дебют Гроба» впервые в истории школьных турниров принёс победу."
            $ leon_intellect += 1
            n "Интеллект Леона увеличен на 1"
            jump prologue_1_article_continue

        "«Легенда о бубновом валете» — призрак, вызываемый через экран монитора?":
            n "Ученики нашей школы снова нашли себе странное развлечение."
            n "По коридорам уже вторую неделю ходят слухи о загадочном Бубновом Валете — призраке, которого можно вызвать через экран монитора."
            n "Для ритуала якобы нужно открыть пустой документ, включить веб-камеру и три раза сказать: «Усатый, приди»."
            n "После этого монитор начинает мерцать, а кулеры компьютера подозрительно шуметь."
            n "Некоторые уверяют, что видели на экране силуэт мужчины с усами и слышали загадочную фразу: «Ну что, чатик». Один старшеклассник попытался вызвать Бубнового Валета на школьном ноутбуке, после чего устройство зависло на четырёхчасовой трансляции."
            n "Особо впечатлительные ученики утверждают, что не могут сосредоточиться на выполнении домашнего задания из-за загадочного призрака."
            n "Администрация школы просит не проводить ритуалы в кабинете информатики, особенно во время уроков."
            n "Хотя, по словам охранника, из компьютерного класса ночью действительно иногда доносится тихое: «Поприветствуйте новичка»."
            $ leon_mystic += 1
            n "Мистика Леона увеличена на 1"
            jump prologue_1_article_continue

        "«Второй мозг» — Как организовать хранение большого объема информации?":
            n "Современные школьники ежедневно получают огромное количество информации."
            n "Домашние задания, даты контрольных, мемы, идеи, списки аниме и внезапные мысли в три часа ночи — всё это уже не помещается в обычной голове."
            n "Именно поэтому среди учеников набирает популярность система под названием Cobblestone. Это место, где ваши заметки не теряются, а связываются друг с другом, как проводные наушники в кармане."
            n "Ученик 3 класса Ямамото-кун вбил туда уже 2000 заметок: от формул по математики до списка лучших ресторанов суши. И теперь он может за две секунды найти связь между интегралами и рецептами риса. Секрет прост: никаких папок, только ссылки. Ты пишешь заметку, ставишь двойные квадратные скобки — и вуаля, у тебя растёт паутина знаний. Однако не все так гладко и удобно, бессмысленные ссылки заметок друг на друга быстро превратят ваши школьные конспекты в карту заговоров из детективного сериала."
            n "Совет редакции: если не хотите, чтобы ваш второй мозг превратился в безумного ученого — подходите к связям осознанно и по возможности создавайте резервные копии."
            $ leon_organization += 1
            n "Организованность Леона увеличена на 1"
            jump prologue_1_article_continue

        "«На одной волне» — Как музыка помогает человеку разобраться в себе?":
            n "У каждого человека есть песня, которую он включает «просто послушать», а потом сидит и смотрит в потолок полчаса."
            n "Музыка давно стала для школьников чем-то большим, чем обычный фон в наушниках."
            n "Кто-то слушает спокойные треки перед экзаменами, кто-то — грустные песни после двойки по алгебре."
            n "Иногда одна случайная строчка из песни понимает тебя лучше, чем все люди вокруг."
            n "Психологи считают, что музыка помогает человеку разобраться в эмоциях и переживаниях."
            n "Не зря многие говорят, что под разную музыку ощущают себя буквально разными людьми."
            n "Некоторые ученики признаются, что именно музыка помогает им собраться с мыслями или пережить сложные моменты."
            n "Ученица второго класса Мори-сан даже начала вести «музыкальный дневник», чтобы лучше понимать своё состояние."
            n "Если за день ты прослушал пять грустных песен — сходи поспи; если слишком долго слушаешь тяжёлый метал — покричи в подушку; если час листаешь плейлист и ничего не включаешь — переключись, развейся, погуляй с друзьями."
            n "Музыка может и не решает проблемы, но хотя бы помогает понять, что ты вообще чувствуешь."
            n "Возможно, именно поэтому она помогает людям быть «на одной волне» — и с другими, и с самими собой."
            $ leon_empathy += 1
            n "Эмпатия Леона увеличена на 1"
            jump prologue_1_article_continue

label prologue_1_article_continue:
    menu:
        "Продолжить"

        "Выбрать другую статью":
            jump prologue_1_article_choice

        "Вернуться к работе":
            return
